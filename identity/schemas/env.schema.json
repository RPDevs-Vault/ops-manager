{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EnvironmentVariablesSchema",
  "type": "object",
  "properties": {
    "SYNC_TOKEN": {
      "type": "string",
      "pattern": "^(ghp|github_pat)_[a-zA-Z0-9_]+$",
      "description": "GitHub Personal Access Token"
    },
    "GH_TOKEN": {
      "type": "string",
      "pattern": "^(ghp|github_pat)_[a-zA-Z0-9_]+$",
      "description": "GitHub CLI token fallback"
    },
    "RUNNER_NAME": {
      "type": "string",
      "description": "Hostname or name of the runner"
    },
    "SHAREDROOT_PATH": {
      "type": "string",
      "description": "NFS Shared root folder mount point"
    }
  },
  "required": ["SYNC_TOKEN"]
}
